---
import { load } from '../lib/data';
const crosslinks = load('crosslinks.yaml');
const items = crosslinks.items || [];
---
{items.length > 0 && (
  <section class="px-5 md:px-6 py-8 md:py-12">
    <div class="max-w-[1100px] mx-auto">
      {crosslinks.heading && (
        <h2 class="font-display text-[24px] md:text-[32px] font-bold text-ink mb-6 tracking-[-0.01em]">
          {crosslinks.heading}
        </h2>
      )}
      <div class="grid grid-cols-1 sm:grid-cols-2 gap-5">
        {items.map((item: any) => (
          <a href={item.url} class="card-glow bg-surface-raised rounded-[8px] p-6 flex items-center justify-between no-underline group">
            <div>
              <p class="font-display text-[19px] font-bold text-ink m-0 mb-1">{item.label}</p>
              {item.description && <p class="text-[14px] text-ink-secondary m-0">{item.description}</p>}
            </div>
            <span class="text-accent text-[20px] transition-transform group-hover:translate-x-1">&rarr;</span>
          </a>
        ))}
      </div>
    </div>
  </section>
)}
