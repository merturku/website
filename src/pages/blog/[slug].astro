---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import { load } from '../../lib/data';

export async function getStaticPaths() {
  const posts = await getCollection('blog');
  return posts.map(post => ({
    params: { slug: post.slug },
    props: { post },
  }));
}

const { post } = Astro.props;
const { Content } = await post.render();
const site = load('site.yaml');

const wordCount = post.body.split(/\s+/).length;
const readTime = Math.ceil(wordCount / 200);
const formattedDate = post.data.date.toLocaleDateString('tr-TR', { year: 'numeric', month: 'long', day: 'numeric' });
const postUrl = `https://merturku.com/blog/${post.slug}`;
---

<BaseLayout title={post.data.title} description={post.data.description}>
  <main class="max-w-[720px] mx-auto px-6 py-20">

    <a href="/blog" class="text-[13px] font-mono text-ink-tertiary hover:text-accent transition-colors mb-10 block">
      ← Blog'a dön
    </a>

    {post.data.tags && post.data.tags.length > 0 && (
      <div class="flex gap-2 mb-4">
        {post.data.tags.map(tag => (
          <span class="text-[11px] font-mono bg-accent-wash text-accent px-2 py-0.5 rounded-full">
            {tag}
          </span>
        ))}
      </div>
    )}

    <h1 class="font-display text-[36px] md:text-[44px] font-bold text-ink leading-tight mb-4">
      {post.data.title}
    </h1>

    <p class="text-ink-secondary text-[17px] leading-relaxed mb-8">
      {post.data.description}
    </p>

    <div class="flex items-center justify-between border-t border-b border-border py-4 mb-10">
      <div class="flex items-center gap-3">
        <div class="w-9 h-9 rounded-full bg-accent-wash flex items-center justify-center text-accent font-bold text-[14px]">
          ME
        </div>
        <div>
          <div class="text-[14px] font-medium text-ink">{site.name}</div>
          <div class="text-[12px] text-ink-tertiary font-mono">{formattedDate} · {readTime} dk okuma</div>
        </div>
      </div>

      <div class="flex items-center gap-3">
        
          href={`https://twitter.com/intent/tweet?text=${encodeURIComponent(post.data.title)}&url=${encodeURIComponent(postUrl)}`}
          target="_blank"
          rel="noopener"
          class="text-ink-tertiary hover:text-accent transition-colors"
          title="Twitter'da paylaş"
        >
          <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor">
            <path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-4.714-6.231-5.401 6.231H2.744l7.73-8.835L1.254 2.25H8.08l4.259 5.63 5.905-5.63zm-1.161 17.52h1.833L7.084 4.126H5.117z"/>
          </svg>
        </a>
        
          href={`https://www.linkedin.com/sharing/share-offsite/?url=${encodeURIComponent(postUrl)}`}
          target="_blank"
          rel="noopener"
          class="text-ink-tertiary hover:text-accent transition-colors"
          title="LinkedIn'de paylaş"
        >
          <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor">
            <path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 01-2.063-2.065 2.064 2.064 0 112.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/>
          </svg>
        </a>
        
          href={`https://www.facebook.com/sharer/sharer.php?u=${encodeURIComponent(postUrl)}`}
          target="_blank"
          rel="noopener"
          class="text-ink-tertiary hover:text-accent transition-colors"
          title="Facebook'ta paylaş"
        >
          <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor">
            <path d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z"/>
          </svg>
        </a>
      </div>
    </div>

    <article class="prose prose-lg max-w-none text-ink-secondary leading-relaxed">
      <Content />
    </article>

  </main>
</BaseLayout>