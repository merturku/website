---
import '../styles/global.css';
import { load } from '../lib/data';

interface Props {
  title: string;
  description: string;
}

const { title, description } = Astro.props;
const canonicalUrl = new URL(Astro.url.pathname, Astro.site);

const site = load('site.yaml');
const hero = load('hero.yaml');
const education = load('education.yaml');

const ogImageUrl = site.ogImage ? new URL(site.ogImage, Astro.site).toString() : undefined;

const themeCss = site.theme ? `
  html:root {
    --color-accent: ${site.theme.light.accent};
    --color-accent-light: ${site.theme.light.accentLight};
    --color-accent-dark: ${site.theme.light.accentDark};
    --color-accent-wash: ${site.theme.light.accentWash};
  }
  html.dark {
    --color-accent: ${site.theme.dark.accent};
    --color-accent-light: ${site.theme.dark.accentLight};
    --color-accent-dark: ${site.theme.dark.accentDark};
    --color-accent-wash: ${site.theme.dark.accentWash};
  }
` : '';
---
<!DOCTYPE html>
<html lang={site.lang || "en"}>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonicalUrl} />
    <meta name="generator" content={Astro.generator} />
    <meta name="color-scheme" content="light dark" />
    {site.themeColor && <meta name="theme-color" content={site.themeColor} />}
    {themeCss && <style set:html={themeCss} />}

    <!-- Prevent flash of wrong theme -->
    <script is:inline>
      (function() {
        var t = localStorage.getItem('theme');
        if (t === 'dark' || (!t && window.matchMedia('(prefers-color-scheme: dark)').matches)) {
          document.documentElement.classList.add('dark');
        }
      })();
    </script>

    <!-- Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link rel="preload" href="https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@400;500;600;700&family=JetBrains+Mono:wght@400;500;600;700&family=IBM+Plex+Sans:wght@400;500;600&display=swap" as="style" />
    <link href="https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@400;500;600;700&family=JetBrains+Mono:wght@400;500;600;700&family=IBM+Plex+Sans:wght@400;500;600&display=swap" rel="stylesheet" />

    <!-- Lord Icon -->
    <script is:inline src="https://cdn.lordicon.com/lordicon.js" defer></script>

    <meta name="robots" content="index, follow" />

    <!-- Open Graph -->
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:type" content="website" />
    <meta property="og:site_name" content={site.fullName || site.name} />
    {ogImageUrl && <meta property="og:image" content={ogImageUrl} />}

    <!-- Twitter -->
    <meta name="twitter:card" content={ogImageUrl ? "summary_large_image" : "summary"} />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    {ogImageUrl && <meta name="twitter:image" content={ogImageUrl} />}

    <!-- JSON-LD -->
    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "Person",
      "name": site.fullName || site.name,
      "url": Astro.site?.toString() || "",
      "jobTitle": hero.subtitle,
      "email": site.email ? `mailto:${site.email}` : undefined,
      "alumniOf": education.institution ? { "@type": "CollegeOrUniversity", "name": education.institution } : undefined,
      "sameAs": (site.social || []).map((s: any) => s.url).filter(Boolean)
    })} />

    <link rel="icon" type="image/svg+xml" href={`${import.meta.env.BASE_URL.replace(/\/?$/, '/')}favicon.svg`} />
  </head>
  <body class="bg-surface text-ink min-h-screen transition-colors duration-300">

    <!-- Preloader — sadece ana sayfa ilk ziyarette -->
    <div id="preloader" class="fixed inset-0 z-[9999] flex flex-col items-center justify-center bg-surface"
         style="display:none !important">
      {site.introText ? (
        <div class="flex flex-col items-center gap-8 px-8">
          <h1 id="pre-word" class="font-display text-[90px] sm:text-[140px] md:text-[180px] font-bold leading-none tracking-[-0.02em] m-0"
              style="-webkit-text-stroke: 2px var(--color-accent); color: transparent;">
            {site.introText}
          </h1>
          <span id="pre-dot" class="w-2.5 h-2.5 rounded-full border-2 border-accent"></span>
        </div>
      ) : (
        <div class="flex flex-col items-start gap-6 px-8">
          <p id="pre-label" class="font-mono text-[11px] tracking-[0.2em] uppercase text-ink-tertiary">
            Deneyim hazırlanıyor
          </p>
          <div class="flex items-end gap-3">
            <span id="pre-count" class="font-display text-[80px] sm:text-[120px] font-bold text-ink leading-none tracking-[-0.03em]">00</span>
            <span class="font-display text-[40px] sm:text-[60px] font-bold text-accent leading-[1.2] mb-1">%</span>
          </div>
          <div class="w-full h-[1px] bg-border overflow-hidden" style="width:min(480px,80vw)">
            <div id="pre-bar" class="h-full bg-accent transition-none" style="width:0%"></div>
          </div>
        </div>
      )}
    </div>

    <div id="page-content" style="opacity:0">
      <slot />
    </div>

    <!-- Scroll reveal observer -->
    <script>
      function initReveal() {
        const els = document.querySelectorAll('.reveal, .reveal-left, .reveal-right, .reveal-scale');
        const observer = new IntersectionObserver((entries) => {
          entries.forEach(entry => {
            if (entry.isIntersecting) {
              entry.target.classList.add('visible');
            }
          });
        }, { threshold: 0.08, rootMargin: '0px 0px -40px 0px' });

        els.forEach(el => observer.observe(el));
      }

      if (document.readyState === 'complete') {
        initReveal();
      } else {
        window.addEventListener('load', initReveal);
      }
    </script>

    <!-- Dark mode toggle + Lord Icon color system -->
    <script>
      function isDark() {
        return document.documentElement.classList.contains('dark');
      }

      function getIconColors() {
        const style = getComputedStyle(document.documentElement);
        const primary = style.getPropertyValue('--color-ink').trim();
        const secondary = style.getPropertyValue('--color-accent').trim();
        return `primary:${primary},secondary:${secondary}`;
      }

      function updateIconColors() {
        const colors = getIconColors();
        document.querySelectorAll('lord-icon').forEach(icon => {
          const current = icon.getAttribute('colors') || '';
          // Don't change icons that use the light (white) color scheme (e.g. icons on accent bg)
          if (current.includes('#ffffff')) return;
          icon.setAttribute('colors', colors);
        });
      }

      function animateToggleIcons() {
        document.querySelectorAll('#theme-toggle svg, #theme-toggle-mobile svg').forEach(svg => {
          if (getComputedStyle(svg).display !== 'none') {
            svg.classList.remove('theme-icon-enter');
            void (svg as HTMLElement).offsetWidth;
            svg.classList.add('theme-icon-enter');
          }
        });
      }

      function setTheme(dark: boolean) {
        document.documentElement.classList.toggle('dark', dark);
        localStorage.setItem('theme', dark ? 'dark' : 'light');
        updateIconColors();
        animateToggleIcons();

        // Update expand button icons if they exist
        const expandBtn = document.getElementById('projects-expand-btn');
        if (expandBtn) {
          const colors = getIconColors();
          expandBtn.querySelectorAll('lord-icon').forEach(icon => {
            icon.setAttribute('colors', colors);
          });
        }
      }

      // Theme toggle button
      document.addEventListener('click', (e) => {
        const btn = (e.target as Element).closest('#theme-toggle, #theme-toggle-mobile');
        if (btn) setTheme(!isDark());
      });

      // Respect system preference changes
      window.matchMedia('(prefers-color-scheme: dark)').addEventListener('change', (e) => {
        if (!localStorage.getItem('theme')) {
          setTheme(e.matches);
        }
      });

      // Lord Icon animation system
      function playIcon(icon: any) {
        if (icon.playerInstance) {
          icon.playerInstance.playFromBeginning();
          icon.classList.remove('icon-animate');
          void icon.offsetWidth;
          icon.classList.add('icon-animate');
        }
      }

      const readyIcons = new Set();

      function onIconReady(icon: any, callback: () => void) {
        if (icon.playerInstance) {
          readyIcons.add(icon);
          callback();
        } else {
          icon.addEventListener('ready', () => {
            readyIcons.add(icon);
            callback();
          });
        }
      }

      function setupIcons() {
        const allIcons = document.querySelectorAll('lord-icon');

        // Set correct colors on load
        updateIconColors();

        allIcons.forEach(icon => {
          onIconReady(icon, () => {
            const parent = icon.closest(
              'a, button, .card-glow, .bg-surface-raised, .bg-surface-sunken, .bg-accent-wash, #email-row, [class*="rounded-[6px]"]'
            );
            if (parent && !['SECTION', 'NAV', 'FOOTER'].includes(parent.tagName)) {
              parent.addEventListener('mouseenter', () => playIcon(icon));
            }
          });
        });

        const revealObserver = new IntersectionObserver((entries) => {
          entries.forEach(entry => {
            if (entry.isIntersecting) {
              const icon = entry.target;
              if (readyIcons.has(icon)) {
                playIcon(icon);
              } else {
                onIconReady(icon, () => playIcon(icon));
              }
            }
          });
        }, { threshold: 0.3 });

        allIcons.forEach(icon => {
          revealObserver.observe(icon);
        });
      }

      window.addEventListener('load', () => {
        setTimeout(setupIcons, 200);
      });
    </script>

    <!-- Preloader script -->
    <script>
      (function () {
        const isHome = window.location.pathname === '/' || window.location.pathname === '/index.html';
        const seen   = sessionStorage.getItem('intro-seen');
        const loader = document.getElementById('preloader') as HTMLElement;
        const page   = document.getElementById('page-content') as HTMLElement;
        const word   = document.getElementById('pre-word') as HTMLElement | null;
        const count  = document.getElementById('pre-count') as HTMLElement | null;
        const bar    = document.getElementById('pre-bar') as HTMLElement | null;

        if (!isHome || seen || !loader) {
          // Alt sayfalar veya tekrar ziyaret: direkt göster
          if (loader) loader.remove();
          if (page) page.style.opacity = '1';
          return;
        }

        // İlk ziyaret, ana sayfa: preloader'ı göster
        loader.style.cssText = '';
        page.style.opacity = '0';

        function exit() {
          sessionStorage.setItem('intro-seen', '1');
          setTimeout(() => {
            loader.style.transition = 'transform 0.7s cubic-bezier(0.76,0,0.24,1), opacity 0.5s ease';
            loader.style.transform  = 'translateY(-100%)';
            loader.style.opacity    = '0';
            page.style.transition   = 'opacity 0.5s ease 0.3s';
            page.style.opacity      = '1';
            setTimeout(() => loader.remove(), 800);
          }, 200);
        }

        if (word) {
          // Kelime çizim animasyonu (ör. "BIM")
          requestAnimationFrame(() => requestAnimationFrame(() => {
            word.classList.add('reveal-word');
          }));
          setTimeout(exit, 1600);
          return;
        }

        if (!count || !bar) { exit(); return; }

        let current = 0;
        const total = 100;
        const duration = 1800; // ms
        const interval = duration / total;

        const timer = setInterval(() => {
          current++;
          const display = String(current).padStart(2, '0');
          count.textContent = display;
          bar.style.width = current + '%';

          if (current >= total) {
            clearInterval(timer);
            exit();
          }
        }, interval);
      })();
    </script>
  </body>
</html>
